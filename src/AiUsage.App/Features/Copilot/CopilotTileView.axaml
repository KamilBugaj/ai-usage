<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:AiUsage.App.Features.Copilot"
             xmlns:conv="using:AiUsage.App.Converters"
             xmlns:ctrl="using:AiUsage.App.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="AiUsage.App.Features.Copilot.CopilotTileView"
             x:DataType="local:CopilotTileViewModel">

    <!-- Padding/radius live in styles so the ultra class can override them. -->
    <UserControl.Styles>
        <Style Selector="Border.tile">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="Border.tile.ultra">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="CornerRadius" Value="5"/>
        </Style>
    </UserControl.Styles>

    <Border Classes="tile" Classes.ultra="{Binding IsUltraCompact}"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource DangerBrush}"
            BorderThickness="{Binding AlertActive, Converter={x:Static conv:BoolToThicknessConverter.Instance}}">
        <Panel>

        <!-- ===== Normal (Small/Large) layout ===== -->
        <StackPanel Spacing="6" IsVisible="{Binding !IsUltraCompact}">

            <Grid ColumnDefinitions="Auto,*,Auto">
                <Viewbox Grid.Column="0" Width="18" Height="18" Margin="0,0,8,0"
                         VerticalAlignment="Center">
                    <Path Data="{StaticResource CopilotLogoGeometry}" Fill="{DynamicResource TextBrush}"/>
                </Viewbox>
                <TextBlock Grid.Column="1" Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="⚠" FontSize="13" VerticalAlignment="Center"
                           Foreground="{DynamicResource DangerBrush}" IsVisible="{Binding AlertActive}"/>
            </Grid>

            <TextBlock Text="Loading…" FontSize="12" Foreground="{DynamicResource MutedBrush}"
                       IsVisible="{Binding IsLoading}"/>

            <TextBlock Text="{Binding ErrorMessage}" FontSize="12" Foreground="{DynamicResource DangerBrush}"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       TextWrapping="Wrap"/>

            <StackPanel Spacing="4" IsVisible="{Binding !IsLoading}">
                <TextBlock Text="{Binding StatusLine}" FontSize="12" Foreground="{DynamicResource SubtextBrush}"/>

                <StackPanel Spacing="2" IsVisible="{Binding HasLimit}">
                    <Grid ColumnDefinitions="*,Auto">
                        <ProgressBar Grid.Column="0" Minimum="0" Maximum="1" Value="{Binding Utilization}"
                                     Height="6" CornerRadius="3" VerticalAlignment="Center"
                                     Background="{DynamicResource TrackBrush}">
                            <ProgressBar.Foreground>
                                <MultiBinding Converter="{x:Static conv:UtilizationToBrushConverter.Instance}">
                                    <Binding Path="Utilization"/>
                                    <Binding Path="AlertThreshold"/>
                                </MultiBinding>
                            </ProgressBar.Foreground>
                        </ProgressBar>
                        <ctrl:ResetRing Grid.Column="1" Margin="6,0,0,0" VerticalAlignment="Center"
                                        Diameter="18" Thickness="3"
                                        RingBrush="{DynamicResource AccentBrush}"
                                        Fraction="{Binding SessionResetFraction}"
                                        ToolTip.Tip="{Binding ResetsAt}"/>
                    </Grid>
                    <TextBlock Text="{Binding ResetsAt}" FontSize="10" Foreground="{DynamicResource MutedBrush}"
                               IsVisible="{Binding IsLarge}"/>
                </StackPanel>

                <TextBlock Text="{Binding UpdatedAt}" FontSize="10" Foreground="{DynamicResource FaintBrush}">
                    <TextBlock.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="UpdatedAt" Converter="{x:Static StringConverters.IsNotNullOrEmpty}"/>
                            <Binding Path="IsLarge"/>
                        </MultiBinding>
                    </TextBlock.IsVisible>
                </TextBlock>
            </StackPanel>

        </StackPanel>

        <!-- ===== Ultra-compact layout: one minimal bar row, details on hover ===== -->
        <StackPanel Spacing="2" IsVisible="{Binding IsUltraCompact}">
            <ToolTip.Tip>
                <StackPanel Spacing="2">
                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding StatusLine}"
                               IsVisible="{Binding StatusLine, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    <TextBlock Text="{Binding ResetsAt}"
                               IsVisible="{Binding ResetsAt, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                    <TextBlock Text="{Binding UpdatedAt}"
                               IsVisible="{Binding UpdatedAt, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>
            </ToolTip.Tip>

            <TextBlock Text="Loading…" FontSize="9" Foreground="{DynamicResource MutedBrush}"
                       IsVisible="{Binding IsLoading}"/>
            <TextBlock Text="{Binding ErrorMessage}" FontSize="9" Foreground="{DynamicResource DangerBrush}"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       TextWrapping="Wrap"/>

            <!-- No bar to show (not connected / needs a paid plan) — surface the status
                 line instead of leaving the tile blank. -->
            <TextBlock Text="{Binding StatusLine}" FontSize="9" Foreground="{DynamicResource MutedBrush}"
                       TextWrapping="Wrap">
                <TextBlock.IsVisible>
                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                        <Binding Path="!IsLoading"/>
                        <Binding Path="!HasLimit"/>
                        <Binding Path="ErrorMessage" Converter="{x:Static StringConverters.IsNullOrEmpty}"/>
                        <Binding Path="StatusLine" Converter="{x:Static StringConverters.IsNotNullOrEmpty}"/>
                    </MultiBinding>
                </TextBlock.IsVisible>
            </TextBlock>

            <!-- [logo] ▓░░ 5% ◔ -->
            <Grid ColumnDefinitions="16,*,30,Auto">
                <Grid.IsVisible>
                    <MultiBinding Converter="{x:Static BoolConverters.And}">
                        <Binding Path="!IsLoading"/>
                        <Binding Path="HasLimit"/>
                    </MultiBinding>
                </Grid.IsVisible>
                <Viewbox Grid.Column="0" Width="12" Height="12"
                         HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Path Data="{StaticResource CopilotLogoGeometry}" Fill="{DynamicResource TextBrush}"/>
                </Viewbox>
                <ProgressBar Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding Utilization}"
                             MinWidth="0" Height="3" CornerRadius="1.5" VerticalAlignment="Center"
                             Background="{DynamicResource TrackBrush}">
                    <ProgressBar.Foreground>
                        <MultiBinding Converter="{x:Static conv:UtilizationToBrushConverter.Instance}">
                            <Binding Path="Utilization"/>
                            <Binding Path="AlertThreshold"/>
                        </MultiBinding>
                    </ProgressBar.Foreground>
                </ProgressBar>
                <TextBlock Grid.Column="2" Text="{Binding UtilizationLabel}" FontSize="9"
                           Foreground="{DynamicResource SubtextBrush}"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
                <ctrl:ResetRing Grid.Column="3" Margin="4,0,0,0" VerticalAlignment="Center"
                                Diameter="11" Thickness="2"
                                RingBrush="{DynamicResource AccentBrush}"
                                Fraction="{Binding SessionResetFraction}"/>
            </Grid>
        </StackPanel>

        </Panel>
    </Border>
</UserControl>
