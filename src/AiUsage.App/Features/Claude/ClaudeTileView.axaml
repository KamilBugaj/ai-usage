<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:AiUsage.App.Features.Claude"
             xmlns:conv="using:AiUsage.App.Converters"
             xmlns:ctrl="using:AiUsage.App.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="AiUsage.App.Features.Claude.ClaudeTileView"
             x:DataType="local:ClaudeTileViewModel">

    <!-- Padding/radius live in styles so the ultra class can override them. -->
    <UserControl.Styles>
        <Style Selector="Border.tile">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="Border.tile.ultra">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="CornerRadius" Value="5"/>
        </Style>
    </UserControl.Styles>

    <Border Classes="tile" Classes.ultra="{Binding IsUltraCompact}"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource DangerBrush}"
            BorderThickness="{Binding AlertActive, Converter={x:Static conv:BoolToThicknessConverter.Instance}}">
        <Panel>

        <!-- ===== Normal (Small/Large) layout ===== -->
        <StackPanel Spacing="6" IsVisible="{Binding !IsUltraCompact}">

            <!-- Header: logo + title + alert badge -->
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Viewbox Grid.Column="0" Width="18" Height="18" Margin="0,0,8,0"
                         VerticalAlignment="Center">
                    <Path Data="{StaticResource ClaudeLogoGeometry}" Fill="#D97757"/>
                </Viewbox>
                <TextBlock Grid.Column="1" Text="{Binding Title}"
                           FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="⚠" FontSize="13"
                           Foreground="{DynamicResource DangerBrush}"
                           VerticalAlignment="Center"
                           IsVisible="{Binding AlertActive}"/>
            </Grid>

            <TextBlock Text="Loading…" FontSize="13" Foreground="{DynamicResource MutedBrush}"
                       IsVisible="{Binding IsLoading}"/>

            <TextBlock Text="{Binding ErrorMessage}" FontSize="13" Foreground="{DynamicResource DangerBrush}"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       TextWrapping="Wrap"/>

            <StackPanel Spacing="6" IsVisible="{Binding !IsLoading}">

                <!-- Session limit bar: "5h [====] 62% ◔" (always shown, both sizes) -->
                <StackPanel Spacing="3" IsVisible="{Binding HasLimit}">
                    <Grid ColumnDefinitions="22,*,38,Auto">
                        <TextBlock Grid.Column="0" Text="5h" FontSize="12"
                                   Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center"/>
                        <ProgressBar Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding Utilization}"
                                     Height="7" CornerRadius="3"
                                     Background="{DynamicResource TrackBrush}">
                            <ProgressBar.Foreground>
                                <MultiBinding Converter="{x:Static conv:UtilizationToBrushConverter.Instance}">
                                    <Binding Path="Utilization"/>
                                    <Binding Path="AlertThreshold"/>
                                </MultiBinding>
                            </ProgressBar.Foreground>
                        </ProgressBar>
                        <TextBlock Grid.Column="2" Text="{Binding UtilizationLabel}" FontSize="12"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        <ctrl:ResetRing Grid.Column="3" Margin="6,0,0,0" VerticalAlignment="Center"
                                        Diameter="18" Thickness="3"
                                        RingBrush="{DynamicResource AccentBrush}"
                                        Fraction="{Binding SessionResetFraction}"
                                        ToolTip.Tip="{Binding ResetsAt}"/>
                    </Grid>
                    <TextBlock Text="{Binding ResetsAt}" FontSize="11" Foreground="{DynamicResource MutedBrush}"
                               Margin="22,0,0,0" IsVisible="{Binding IsLarge}"/>
                </StackPanel>

                <!-- Weekly limit bar (both sizes; reset text large only) -->
                <StackPanel Spacing="3" IsVisible="{Binding HasWeeklyLimit}">
                    <Grid ColumnDefinitions="22,*,38,Auto">
                        <TextBlock Grid.Column="0" Text="7d" FontSize="12"
                                   Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center"/>
                        <ProgressBar Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding WeeklyUtilization}"
                                     Height="7" CornerRadius="3"
                                     Background="{DynamicResource TrackBrush}">
                            <ProgressBar.Foreground>
                                <MultiBinding Converter="{x:Static conv:UtilizationToBrushConverter.Instance}">
                                    <Binding Path="WeeklyUtilization"/>
                                    <Binding Path="AlertThreshold"/>
                                </MultiBinding>
                            </ProgressBar.Foreground>
                        </ProgressBar>
                        <TextBlock Grid.Column="2" Text="{Binding WeeklyLabel}" FontSize="12"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        <ctrl:ResetRing Grid.Column="3" Margin="6,0,0,0" VerticalAlignment="Center"
                                        Diameter="18" Thickness="3"
                                        RingBrush="{DynamicResource AccentBrush}"
                                        Fraction="{Binding WeeklyResetFraction}"
                                        ToolTip.Tip="{Binding WeeklyResetsAt}"/>
                    </Grid>
                    <TextBlock Text="{Binding WeeklyResetsAt}" FontSize="11"
                               Foreground="{DynamicResource MutedBrush}" Margin="22,0,0,0"
                               IsVisible="{Binding IsLarge}"/>
                </StackPanel>

                <!-- Last updated (large only) -->
                <TextBlock Text="{Binding UpdatedAt}" FontSize="10" Foreground="{DynamicResource FaintBrush}">
                    <TextBlock.IsVisible>
                        <MultiBinding Converter="{x:Static BoolConverters.And}">
                            <Binding Path="UpdatedAt" Converter="{x:Static StringConverters.IsNotNullOrEmpty}"/>
                            <Binding Path="IsLarge"/>
                        </MultiBinding>
                    </TextBlock.IsVisible>
                </TextBlock>

            </StackPanel>
        </StackPanel>

        <!-- ===== Ultra-compact layout: two minimal bar rows, details on hover ===== -->
        <StackPanel Spacing="2" IsVisible="{Binding IsUltraCompact}">
            <ToolTip.Tip>
                <StackPanel Spacing="2">
                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding ResetsAt, StringFormat='5h {0}'}"
                               IsVisible="{Binding HasLimit}"/>
                    <TextBlock Text="{Binding WeeklyResetsAt, StringFormat='7d {0}'}"
                               IsVisible="{Binding HasWeeklyLimit}"/>
                    <TextBlock Text="{Binding UpdatedAt}"
                               IsVisible="{Binding UpdatedAt, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>
            </ToolTip.Tip>

            <TextBlock Text="Loading…" FontSize="9" Foreground="{DynamicResource MutedBrush}"
                       IsVisible="{Binding IsLoading}"/>
            <TextBlock Text="{Binding ErrorMessage}" FontSize="9" Foreground="{DynamicResource DangerBrush}"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                       TextWrapping="Wrap"/>

            <StackPanel Spacing="2" IsVisible="{Binding !IsLoading}">
                <!-- [logo] 5h ▓▓▓ 43% ◔ -->
                <Grid ColumnDefinitions="16,18,*,30,Auto" IsVisible="{Binding HasLimit}">
                    <Viewbox Grid.Column="0" Width="12" Height="12"
                             HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Path Data="{StaticResource ClaudeLogoGeometry}" Fill="#D97757"/>
                    </Viewbox>
                    <TextBlock Grid.Column="1" Text="5h" FontSize="9"
                               Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center"/>
                    <ProgressBar Grid.Column="2" Minimum="0" Maximum="1" Value="{Binding Utilization}"
                                 MinWidth="0" Height="3" CornerRadius="1.5" VerticalAlignment="Center"
                                 Background="{DynamicResource TrackBrush}">
                        <ProgressBar.Foreground>
                            <MultiBinding Converter="{x:Static conv:UtilizationToBrushConverter.Instance}">
                                <Binding Path="Utilization"/>
                                <Binding Path="AlertThreshold"/>
                            </MultiBinding>
                        </ProgressBar.Foreground>
                    </ProgressBar>
                    <TextBlock Grid.Column="3" Text="{Binding UtilizationLabel}" FontSize="9"
                               Foreground="{DynamicResource SubtextBrush}"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    <ctrl:ResetRing Grid.Column="4" Margin="4,0,0,0" VerticalAlignment="Center"
                                    Diameter="11" Thickness="2"
                                    RingBrush="{DynamicResource AccentBrush}"
                                    Fraction="{Binding SessionResetFraction}"/>
                </Grid>

                <!-- (empty logo cell) 7d ▓▓▓ 31% ◔ -->
                <Grid ColumnDefinitions="16,18,*,30,Auto" IsVisible="{Binding HasWeeklyLimit}">
                    <TextBlock Grid.Column="1" Text="7d" FontSize="9"
                               Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center"/>
                    <ProgressBar Grid.Column="2" Minimum="0" Maximum="1" Value="{Binding WeeklyUtilization}"
                                 MinWidth="0" Height="3" CornerRadius="1.5" VerticalAlignment="Center"
                                 Background="{DynamicResource TrackBrush}">
                        <ProgressBar.Foreground>
                            <MultiBinding Converter="{x:Static conv:UtilizationToBrushConverter.Instance}">
                                <Binding Path="WeeklyUtilization"/>
                                <Binding Path="AlertThreshold"/>
                            </MultiBinding>
                        </ProgressBar.Foreground>
                    </ProgressBar>
                    <TextBlock Grid.Column="3" Text="{Binding WeeklyLabel}" FontSize="9"
                               Foreground="{DynamicResource SubtextBrush}"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    <ctrl:ResetRing Grid.Column="4" Margin="4,0,0,0" VerticalAlignment="Center"
                                    Diameter="11" Thickness="2"
                                    RingBrush="{DynamicResource AccentBrush}"
                                    Fraction="{Binding WeeklyResetFraction}"/>
                </Grid>
            </StackPanel>
        </StackPanel>

        </Panel>
    </Border>
</UserControl>
